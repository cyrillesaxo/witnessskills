# WitnessSkills Environment Variables
# Copy this file to .env and fill in the values

# ===========================================
# SUPABASE (Required)
# Get from: Supabase Dashboard -> Settings -> API
# ===========================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# DATABASE (Supabase SQL editor)
# Fresh project: run supabase/setup_all.sql
# Existing project: run supabase/migrations/20260615000001_add_rct_fields_to_skills.sql
# ===========================================

# ===========================================
# LOCAL AI (optional — Netlify Functions)
# Terminal 1: npm run dev:netlify
# Terminal 2: npm run dev
# Set ANTHROPIC_API_KEY in Netlify env or .env for netlify dev
# ===========================================
# ANTHROPIC_API_KEY=sk-ant-...
